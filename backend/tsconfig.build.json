{
    "extends": "./tsconfig.json",
    "compilerOptions": {
      "module": "commonjs",
      "moduleResolution": "node",
      "outDir": "dist",
      "target": "ES2020",
      "esModuleInterop": true,
      "resolveJsonModule": true,
      "sourceMap": false,
      "declaration": false,
      "noEmit": false
    },
    "include": ["src"]
  }
  